# App
APP_ENV=development
HOST=0.0.0.0
PORT=8080

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/app_development

# Auth (disabled by default — enable JWT middleware in src/routes/mod.rs)
JWT_SECRET=change-me-in-production
JWT_EXPIRATION_SECS=3600

# Logging (see https://docs.rs/tracing-subscriber/latest/tracing_subscriber/filter/struct.EnvFilter.html)
RUST_LOG=app=debug,tower_http=debug
